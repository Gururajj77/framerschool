---
import Logo from './Logo.astro';

interface Props {
  size?: 'sm' | 'md' | 'lg';
  showLogo?: boolean;
  class?: string;
}

const { size = 'md', showLogo = true, class: className = '' } = Astro.props;
const logoSizes = { sm: 28, md: 34, lg: 40 };
---

<span class:list={['pf-wordmark', `pf-wordmark--${size}`, className]} aria-label="FramerSchool">
  {showLogo && <Logo size={logoSizes[size]} class="pf-wordmark-logo" />}
  <span class="pf-wordmark-text">
    <span class="pf-wordmark-framer">framer</span>
    <span class="pf-wordmark-school">school</span>
  </span>
</span>
