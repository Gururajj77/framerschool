---
import { KNOTCMS_URL } from '../config';
import Wordmark from './Wordmark.astro';

const links = [
  { href: '#home', label: 'Home' },
  { href: '#features', label: 'Programs' },
  { href: '#approach', label: 'Approach' },
  { href: '#knotcms', label: 'KnotCMS' },
  { href: '#faq', label: 'FAQ' },
];
---

<footer class="pf-site-footer">
  <div class="pf-site-footer-inner">
    <div>
      <Wordmark size="sm" />
      <p class="pf-site-footer-tagline">Build client-ready Framer sites from templates.</p>
    </div>

    <nav class="pf-site-footer-nav" aria-label="Footer">
      {links.map((link) => (
        <a href={link.href}>{link.label}</a>
      ))}
      <a href={KNOTCMS_URL} target="_blank" rel="noopener noreferrer">Open KnotCMS</a>
      <a href="#home">Back to top</a>
    </nav>

    <p class="pf-site-footer-copy">&copy; 2026 FramerSchool. All rights reserved.</p>
  </div>
</footer>
