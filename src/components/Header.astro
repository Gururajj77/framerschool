---
import { KNOTCMS_URL } from '../config';
import Wordmark from './Wordmark.astro';

const links = [
  { href: '#process', label: 'Process' },
  { href: '#features', label: 'Programs' },
  { href: '#approach', label: 'Approach' },
  { href: '#knotcms', label: 'KnotCMS' },
  { href: '#faq', label: 'FAQ' },
];
---

<header class="pf-topbar" data-topbar>
  <div class="pf-container pf-topbar-shell">
    <a href="#home" class="pf-topbar-brand" aria-label="FramerSchool home">
      <Wordmark size="md" />
    </a>

    <nav id="site-nav" class="pf-site-nav" aria-label="Main" data-site-nav>
      <div class="pf-site-nav-track">
        {links.map((link) => (
          <a href={link.href} class="pf-site-nav-link">{link.label}</a>
        ))}
        <div class="pf-site-nav-mobile-actions">
          <a href={KNOTCMS_URL} class="pf-topbar-login pf-topbar-login--mobile" target="_blank" rel="noopener noreferrer">
            KnotCMS
          </a>
          <a href="#contact" class="pf-btn pf-btn--primary pf-btn--sm">Get in touch</a>
        </div>
      </div>
    </nav>

    <div class="pf-topbar-actions">
      <a href={KNOTCMS_URL} class="pf-topbar-login" target="_blank" rel="noopener noreferrer">KnotCMS</a>
      <a href="#contact" class="pf-btn pf-btn--primary pf-btn--sm pf-topbar-cta">Get in touch</a>
      <button
        class="pf-site-nav-toggle"
        data-nav-toggle
        type="button"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="site-nav"
      >
        <span class="pf-site-nav-toggle-icon" aria-hidden="true">
          <span></span>
          <span></span>
        </span>
      </button>
    </div>
  </div>
</header>
