---
import Wordmark from './Wordmark.astro';

const links = [
  { href: '#home', label: 'Home' },
  { href: '#features', label: 'Features' },
  { href: '#knotcms', label: 'KnotCMS' },
  { href: '#faq', label: 'FAQ' },
  { href: '#contact', label: 'Contact Us' },
];
---

<header class="pf-topbar" data-topbar>
  <a href="#home" class="pf-topbar-brand">
    <Wordmark size="md" />
  </a>

  <nav class="pf-site-nav" aria-label="Main">
    {links.map((link) => (
      <a href={link.href} class="pf-site-nav-link">{link.label}</a>
    ))}
  </nav>

  <div class="pf-topbar-spacer"></div>

  <a href="#contact" class="pf-btn pf-btn--primary pf-topbar-cta">Explore Website</a>

  <button class="pf-site-nav-toggle" data-nav-toggle type="button" aria-label="Toggle menu">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <path d="M4 7h16M4 12h16M4 17h16" />
    </svg>
  </button>
</header>
