---
import Wordmark from './Wordmark.astro';
import { CONTACT_EMAIL } from '../config';

const links = [
  { href: '#process', label: 'Process' },
  { href: '#features', label: 'Programs' },
  { href: '#approach', label: 'Approach' },
  { href: '#knotcms', label: 'KnotCMS' },
  { href: '#faq', label: 'FAQ' },
  { href: '#contact', label: 'Contact' },
];
---

<header class="pf-topbar" data-topbar>
  <div class="pf-container pf-topbar-inner">
    <a href="#home" class="pf-topbar-brand" aria-label="FramerSchool home">
      <Wordmark size="sm" />
    </a>

    <nav class="pf-topbar-nav" id="site-nav" aria-label="Main" data-site-nav>
      {links.map((link) => (
        <a href={link.href} class="pf-topbar-link" data-nav-label={link.label}>
          {link.label}
        </a>
      ))}
    </nav>

    <div class="pf-topbar-actions">
      <a href={`mailto:${CONTACT_EMAIL}`} class="pf-topbar-mail">Email</a>
      <a href="#contact" class="pf-btn pf-btn--primary pf-btn--sm">Get in touch</a>
      <button
        class="pf-topbar-toggle"
        data-nav-toggle
        type="button"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="nav-overlay"
      >
        <span></span>
        <span></span>
      </button>
    </div>
  </div>
</header>

<div class="pf-nav-overlay" id="nav-overlay" data-nav-overlay aria-hidden="true">
  <div class="pf-nav-overlay-inner">
    <nav class="pf-nav-overlay-nav" aria-label="Mobile">
      {links.map((link) => (
        <a href={link.href} class="pf-nav-overlay-link" data-nav-overlay-link>
          {link.label}
        </a>
      ))}
      <a href="#home" class="pf-nav-overlay-link" data-nav-overlay-link>Home</a>
    </nav>
  </div>
</div>
