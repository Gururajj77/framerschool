---
import { KNOTCMS_URL, KNOTCMS_DOCS_URL } from '../config';
import HeroBridge from './HeroBridge.astro';

const capabilities = [
  {
    index: '.01',
    title: 'Match fields once',
    items: [
      'Connect Notion in minutes',
      'Map each field to Framer CMS',
      'Manage sync from one dashboard',
    ],
  },
  {
    index: '.02',
    title: 'Updates on their own',
    items: [
      'Notion changes flow to Framer',
      'No exports or copy-paste',
      'Automatic sync on paid plans',
    ],
  },
  {
    index: '.03',
    title: 'Publish when ready',
    items: [
      'Review synced content first',
      'Push live when you are ready',
      'Ship client sites with confidence',
    ],
  },
];
---

<section id="knotcms" class="pf-section pf-section--knotcms">
  <div class="pf-container pf-knotcms-oberon">
    <aside class="pf-knotcms-sidebar" data-knotcms-sidebar>
      <span class="pf-knotcms-tag">07 KnotCMS</span>
      <p class="pf-eyebrow">From FramerSchool</p>
      <h2 class="pf-knot-title">
        Sync Notion to Framer CMS
        <span class="pf-knot-title-accent">without the busywork</span>
      </h2>
      <p class="pf-knot-lead">
        KnotCMS is our sync tool for Framer creators. It keeps your Framer CMS updated from Notion
        — match fields once, and sync automatically on paid plans.
      </p>

      <div class="pf-knotcms-foot">
        <span class="pf-knotcms-foot-label">FramerSchool</span>
        <p class="pf-knotcms-foot-copy">Built for Framer freelancers shipping client-ready sites.</p>
      </div>
    </aside>

    <div class="pf-knotcms-main">
      <div class="pf-knot-visual" data-knot-bridge-wrap>
        <HeroBridge />
      </div>

      <div class="pf-knotcms-grid" data-knotcms-grid>
        {capabilities.map((capability) => (
          <article class="pf-knotcms-cell" data-knot-feature>
            <span class="pf-knotcms-cell-index">{capability.index}</span>
            <h3 class="pf-knotcms-cell-title">{capability.title}</h3>
            <ul class="pf-knotcms-cell-list">
              {capability.items.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </article>
        ))}
      </div>

      <div class="pf-knot-actions">
        <a href={KNOTCMS_URL} class="pf-btn pf-btn--primary" target="_blank" rel="noopener noreferrer">
          Get started free
        </a>
        <a href={`${KNOTCMS_URL}/setup`} class="pf-btn pf-btn--secondary" target="_blank" rel="noopener noreferrer">
          Start setup
        </a>
        <a href={KNOTCMS_DOCS_URL} class="pf-btn pf-btn--ghost" target="_blank" rel="noopener noreferrer">
          Read docs
        </a>
      </div>
    </div>
  </div>
</section>
