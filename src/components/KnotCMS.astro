---
import { KNOTCMS_URL, KNOTCMS_DOCS_URL } from '../config';
import HeroBridge from './HeroBridge.astro';
import SectionHead from './SectionHead.astro';

const capabilities = [
  { index: '01', title: 'Match fields once' },
  { index: '02', title: 'Updates on their own' },
  { index: '03', title: 'Publish when ready' },
];
---

<section id="knotcms" class="pf-section">
  <div class="pf-container">
    <SectionHead
      tag="KNOTCMS"
      title="Sync Notion to Framer CMS without the busywork"
      lead="KnotCMS keeps your Framer CMS updated from Notion — match fields once, and sync automatically on paid plans."
    />

    <div class="pf-knot-layout">
      <div class="pf-knot-copy">
        <p class="pf-knot-eyebrow">From FramerSchool</p>
        <ul class="pf-knot-list">
          <li>Connect Notion and map each field to Framer CMS from one dashboard.</li>
          <li>On paid plans, changes in Notion show up in Framer automatically.</li>
          <li>Push synced content live when you are ready to ship.</li>
        </ul>
        <div class="pf-knot-actions">
          <a href={KNOTCMS_URL} class="pf-btn pf-btn--primary" target="_blank" rel="noopener noreferrer">
            Get started free
          </a>
          <a href={`${KNOTCMS_URL}/setup`} class="pf-btn pf-btn--outline" target="_blank" rel="noopener noreferrer">
            Start setup
          </a>
          <a href={KNOTCMS_DOCS_URL} class="pf-btn pf-btn--ghost" target="_blank" rel="noopener noreferrer">
            Read docs
          </a>
        </div>
      </div>

      <div class="pf-knot-visual" data-knot-bridge-wrap>
        <HeroBridge />
      </div>
    </div>

    <div class="pf-services pf-services--compact">
      {capabilities.map((item) => (
        <article class="pf-service" data-knot-feature>
          <p class="pf-service-index" aria-hidden="true">
            <span>/</span>
            <span>{item.index}</span>
            <span>.</span>
          </p>
          <h3 class="pf-service-title">{item.title}</h3>
        </article>
      ))}
    </div>
  </div>
</section>
