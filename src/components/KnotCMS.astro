---
import { KNOTCMS_URL, KNOTCMS_DOCS_URL } from '../config';
import HeroBridge from './HeroBridge.astro';

const features = [
  {
    title: 'Match fields once',
    description: 'Connect Notion, line up each field with Framer CMS, and manage everything from one dashboard.',
    icon: 'workflow',
  },
  {
    title: 'Updates on their own',
    description: 'On paid plans, changes in Notion show up in Framer automatically. No exports or copy-paste.',
    icon: 'refresh',
  },
  {
    title: 'Publish when ready',
    description: 'Push synced content to your live Framer site when you are ready to ship.',
    icon: 'sparkles',
  },
];
---

<section id="knotcms" class="pf-band">
  <div class="pf-container pf-knot-grid">
    <div class="pf-knot-copy">
      <p class="pf-eyebrow">From FramerSchool</p>
      <h2 class="pf-knot-title">
        Sync Notion to Framer CMS
        <span class="pf-knot-title-accent">without the busywork</span>
      </h2>
      <p class="pf-knot-lead">
        KnotCMS is our sync tool for Framer creators. It keeps your Framer CMS updated from Notion
        — match fields once, and sync automatically on paid plans.
      </p>

      <ul class="pf-login-features pf-knot-features">
        {features.map((feature) => (
          <li class="pf-login-feature">
            <span class="pf-login-feature-icon" aria-hidden="true">
              {feature.icon === 'workflow' && (
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <rect x="3" y="3" width="6" height="6" rx="1" />
                  <rect x="15" y="15" width="6" height="6" rx="1" />
                  <path d="M9 6h6M6 9v6M18 15H9" />
                </svg>
              )}
              {feature.icon === 'refresh' && (
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M21 12a9 9 0 1 1-3-6.7" />
                  <path d="M21 3v6h-6" />
                </svg>
              )}
              {feature.icon === 'sparkles' && (
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M12 3l1.5 4.5L18 9l-4.5 1.5L12 15l-1.5-4.5L6 9l4.5-1.5L12 3z" />
                </svg>
              )}
            </span>
            <div>
              <strong>{feature.title}</strong>
              <p>{feature.description}</p>
            </div>
          </li>
        ))}
      </ul>

      <div class="pf-knot-actions">
        <a href={KNOTCMS_URL} class="pf-btn pf-btn--primary" target="_blank" rel="noopener noreferrer">
          Get started free
        </a>
        <a href={`${KNOTCMS_URL}/setup`} class="pf-btn pf-btn--secondary" target="_blank" rel="noopener noreferrer">
          Start setup
        </a>
        <a href={KNOTCMS_DOCS_URL} class="pf-btn pf-btn--ghost" target="_blank" rel="noopener noreferrer">
          Read docs
        </a>
      </div>
    </div>

    <div class="pf-knot-visual">
      <HeroBridge />
    </div>
  </div>
</section>
