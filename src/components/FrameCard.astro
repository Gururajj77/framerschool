---
interface Props {
  number: string;
  title: string;
  description?: string;
  icon: 'layout' | 'edit' | 'ship' | 'handoff' | 'structure' | 'judgment' | 'delivery' | 'cms';
  class?: string;
  reveal?: boolean;
  programCard?: boolean;
}

const {
  number,
  title,
  description,
  icon,
  class: className,
  reveal = false,
  programCard = false,
} = Astro.props;
---

<article
  class:list={['pf-frame-card', className]}
  {...(reveal ? { 'data-process-card': true } : {})}
  {...(programCard ? { 'data-program-card': true } : {})}
>
  <span class="pf-frame-corner pf-frame-corner--tl" aria-hidden="true"></span>
  <span class="pf-frame-corner pf-frame-corner--tr" aria-hidden="true"></span>
  <span class="pf-frame-corner pf-frame-corner--bl" aria-hidden="true"></span>
  <span class="pf-frame-corner pf-frame-corner--br" aria-hidden="true"></span>

  <div class="pf-frame-card-top">
    <p class="pf-frame-card-num" aria-hidden="true">
      <span>{number}</span><span class="pf-frame-card-dot">.</span>
    </p>
    <span class="pf-frame-card-icon" aria-hidden="true">
      {icon === 'layout' && (
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <rect x="3" y="3" width="7" height="7" rx="1" />
          <rect x="14" y="3" width="7" height="7" rx="1" />
          <rect x="3" y="14" width="7" height="7" rx="1" />
          <rect x="14" y="14" width="7" height="7" rx="1" />
        </svg>
      )}
      {icon === 'edit' && (
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M12 20h9" />
          <path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4Z" />
        </svg>
      )}
      {icon === 'ship' && (
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M5 12l5 5L20 7" />
        </svg>
      )}
      {icon === 'handoff' && (
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8Z" />
          <path d="M14 2v6h6M16 13H8M16 17H8M10 9H8" />
        </svg>
      )}
      {icon === 'structure' && (
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M4 6h16M4 12h10M4 18h16" />
        </svg>
      )}
      {icon === 'judgment' && (
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <circle cx="12" cy="12" r="9" />
          <path d="M12 7v5l3 2" />
        </svg>
      )}
      {icon === 'delivery' && (
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M22 12H2" />
          <path d="M5 12v6a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2v-6" />
          <path d="M7 12V7a2 2 0 0 1 2-2h6a2 2 0 0 1 2 2v5" />
        </svg>
      )}
      {icon === 'cms' && (
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <ellipse cx="12" cy="5" rx="9" ry="3" />
          <path d="M3 5v14a9 3 0 0 0 18 0V5" />
          <path d="M3 12a9 3 0 0 0 18 0" />
        </svg>
      )}
    </span>
  </div>

  <div class="pf-frame-card-body">
    <h3 class="pf-frame-card-title">{title}</h3>
    {description && <p class="pf-frame-card-text">{description}</p>}
  </div>
</article>
