---
interface Props {
  size?: number;
  class?: string;
}

const { size = 32, class: className = '' } = Astro.props;
const height = Math.round(size * (673 / 624));
---

<img
  src="/brand/fs-logo.svg"
  width={size}
  height={height}
  alt=""
  class:list={['pf-logo', className]}
  decoding="async"
/>
