---
import SectionHead from './SectionHead.astro';

const faqs = [
  {
    question: 'Do I need to design from scratch?',
    answer:
      'No. Templates already solve most layout problems. The real skill is knowing what to change and what to remove.',
  },
  {
    question: 'Can I use templates for client work?',
    answer:
      'Yes. Templates are a starting point. You adapt structure, copy, and sections to match each client\'s business and goals.',
  },
  {
    question: 'What do you actually teach?',
    answer:
      'How to evaluate a business, pick the right site type, strip unnecessary sections, adjust hierarchy and flow, and deliver client-ready Framer sites you can sell with confidence.',
  },
  {
    question: 'Do I need to be good at design?',
    answer:
      'No advanced design skills required. You need judgment — knowing what to keep, what to cut, and how to shape a site around real business goals.',
  },
];
---

<section id="faq" class="pf-section pf-section--muted">
  <div class="pf-container">
    <SectionHead
      tag="FAQS"
      title="Things to know before working with us"
      lead="Quick answers about programs, templates, and how FramerSchool works."
    />

    <div class="pf-faq-list" role="list">
      {faqs.map((faq) => (
        <div class="pf-faq-item" data-faq-item role="listitem">
          <h3 class="pf-faq-heading">
            <button class="pf-faq-trigger" data-faq-toggle type="button" aria-expanded="false">
              <span class="pf-faq-qmark" aria-hidden="true">/</span>
              <span class="pf-faq-question-text">{faq.question}</span>
              <span class="pf-faq-icon" aria-hidden="true">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                  <path d="M12 5v14M5 12h14" />
                </svg>
              </span>
            </button>
          </h3>
          <div class="pf-faq-panel" data-faq-panel>
            <div class="pf-faq-panel-inner">
              <p>{faq.answer}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
