---
import SectionHead from './SectionHead.astro';

const points = [
  {
    title: 'Structure before polish',
    text: 'Pick layout that fits the business. Hierarchy before decoration. Every section earns its place.',
  },
  {
    title: 'Judgment over copying',
    text: 'Templates are a starting point. Cut what does not serve the client. Adapt with intent, not guesswork.',
  },
  {
    title: 'Delivery you can defend',
    text: 'Ship sites you can explain to clients — with clear structure, trimmed sections, and confident handoff.',
  },
];
---

<section id="approach" class="pf-section pf-section--muted">
  <div class="pf-container">
    <SectionHead
      tag="APPROACH"
      title="Why structure comes first"
      lead="Most people build Framer sites backwards. We teach the opposite — structure, judgment, then polish."
    />

    <div class="pf-points" data-approach-grid>
      {points.map((point, index) => (
        <article class="pf-point" data-approach-cell>
          <p class="pf-point-index" aria-hidden="true">
            <span>/</span>
            <span>{String(index + 1).padStart(2, '0')}</span>
            <span>.</span>
          </p>
          <h3 class="pf-point-title">{point.title}</h3>
          <p class="pf-point-text">{point.text}</p>
        </article>
      ))}
    </div>
  </div>
</section>
