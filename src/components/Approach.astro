---
const othersDo = [
  'Copy templates page for page',
  'Add sections without a reason',
  'Focus on visuals before structure',
  'Build without understanding the business',
];

const weFocus = [
  'Where the business is today',
  'What the site needs to do',
  'Structure and page flow',
  'What to keep and what to cut',
];
---

<section id="approach" class="pf-section">
  <div class="pf-section-head pf-section-head--center">
    <p class="pf-eyebrow">Our approach</p>
    <h2 class="pf-section-title">Most people build websites backwards</h2>
    <p class="pf-section-lead">
      Templates are a shortcut, not the answer. The skill is knowing what to change.
    </p>
  </div>

  <div class="pf-compare-grid">
    <article class="pf-card pf-compare-card">
      <div class="pf-card-header">
        <h3 class="pf-card-title">What most people do</h3>
      </div>
      <ul class="pf-compare-list">
        {othersDo.map((item) => (
          <li>
            <span class="pf-compare-marker pf-compare-marker--bad" aria-hidden="true">×</span>
            {item}
          </li>
        ))}
      </ul>
    </article>

    <article class="pf-card pf-compare-card pf-compare-card--focus">
      <div class="pf-card-header">
        <h3 class="pf-card-title">What we focus on</h3>
      </div>
      <ul class="pf-compare-list">
        {weFocus.map((item) => (
          <li>
            <span class="pf-compare-marker pf-compare-marker--good" aria-hidden="true">✓</span>
            {item}
          </li>
        ))}
      </ul>
    </article>
  </div>
</section>
