---
import SectionHead from './SectionHead.astro';
import FrameCard from './FrameCard.astro';

const programs = [
  { index: '01', title: 'Site structure', icon: 'structure' as const },
  { index: '02', title: 'Template judgment', icon: 'judgment' as const },
  { index: '03', title: 'Client delivery', icon: 'delivery' as const },
  { index: '04', title: 'Framer CMS', icon: 'cms' as const },
];
---

<section id="features" class="pf-section pf-section--grid">
  <div class="pf-container">
    <SectionHead
      tag="PROGRAMS"
      title="What we help Framer freelancers master"
      lead="We do not teach page-for-page cloning. We teach the judgment to pick structure, cut noise, and ship work clients pay for."
    />

    <div class="pf-frame-grid pf-frame-grid--4">
      {programs.map((program) => (
        <FrameCard
          number={program.index}
          title={program.title}
          icon={program.icon}
          class="pf-frame-card--compact"
          programCard
        />
      ))}
    </div>

    <div class="pf-section-cta">
      <a href="#contact" class="pf-btn pf-btn--primary">Get started</a>
    </div>
  </div>
</section>
