---
import SectionHead from './SectionHead.astro';

const programs = [
  { index: '01', title: 'Site structure' },
  { index: '02', title: 'Template judgment' },
  { index: '03', title: 'Client delivery' },
  { index: '04', title: 'Framer CMS' },
];
---

<section id="features" class="pf-section">
  <div class="pf-container">
    <SectionHead
      tag="PROGRAMS"
      title="What we help Framer freelancers master"
      lead="We do not teach page-for-page cloning. We teach the judgment to pick structure, cut noise, and ship work clients pay for."
    />

    <div class="pf-services">
      {programs.map((program) => (
        <article class="pf-service" data-program-card>
          <p class="pf-service-index" aria-hidden="true">
            <span>/</span>
            <span>{program.index}</span>
            <span>.</span>
          </p>
          <h3 class="pf-service-title">{program.title}</h3>
        </article>
      ))}
    </div>

    <div class="pf-section-cta">
      <a href="#contact" class="pf-btn pf-btn--primary">Get started</a>
    </div>
  </div>
</section>
