---
const features = [
  {
    title: 'Pick the right site type',
    description:
      'Different businesses need different structures. Start with what actually fits the client — not what looks coolest.',
  },
  {
    title: 'Understand why it works',
    description:
      'Layout, hierarchy, and flow shape attention and action. Good structure builds trust before polish does.',
  },
  {
    title: 'Adapt and ship',
    description:
      'Use templates as a starting point, then remove and reshape based on the business — with confidence.',
  },
];
---

<section id="features" class="pf-band pf-band--muted">
  <div class="pf-container pf-section-block">
    <div class="pf-section-head pf-section-head--center">
      <p class="pf-eyebrow">Programs</p>
      <h2 class="pf-section-title">Learn with a clear plan</h2>
      <p class="pf-section-lead">
        Practical programs focused on real client work — not abstract design theory.
      </p>
    </div>

    <div class="pf-feature-grid">
      {features.map((feature) => (
        <article class="pf-feature-card">
          <h3 class="pf-feature-title">{feature.title}</h3>
          <p class="pf-feature-desc">{feature.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>
