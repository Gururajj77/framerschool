---
import { CONTACT_EMAIL } from '../config';
---

<section id="contact" class="pf-cta-band">
  <div class="pf-cta-panel">
    <div class="pf-cta-copy">
      <p class="pf-eyebrow">Get in touch</p>
      <h2 class="pf-cta-title">Ready to build better client sites?</h2>
      <p class="pf-cta-desc">
        Reach out to learn about programs, coaching, or how FramerSchool can help you ship
        client-ready Framer websites.
      </p>
    </div>
    <div class="pf-cta-actions">
      <a href={`mailto:${CONTACT_EMAIL}`} class="pf-btn pf-btn--primary pf-btn--lg">Email us</a>
      <a href="#features" class="pf-btn pf-btn--secondary pf-btn--lg">See programs</a>
    </div>
  </div>
</section>
