---
import { CONTACT_EMAIL } from '../config';
import SectionHead from './SectionHead.astro';
---

<section id="contact" class="pf-section">
  <div class="pf-container pf-contact">
    <SectionHead
      tag="CONTACT"
      title="Start a conversation with us"
      lead="Tell us about your Framer work and goals — we will help you ship sites clients pay for."
    />

    <div class="pf-contact-details" data-cta-panel>
      <a href={`mailto:${CONTACT_EMAIL}`} class="pf-contact-email">{CONTACT_EMAIL}</a>
    </div>

    <div class="pf-contact-actions">
      <a href={`mailto:${CONTACT_EMAIL}`} class="pf-btn pf-btn--primary pf-btn--lg">Email us</a>
      <a href="#features" class="pf-btn pf-btn--outline pf-btn--lg">See programs</a>
    </div>
  </div>
</section>
