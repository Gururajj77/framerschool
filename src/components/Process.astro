---
import SectionHead from './SectionHead.astro';

const steps = [
  {
    number: '01',
    title: 'Pick the right template',
    description:
      'Start with a layout that matches the business — not the flashiest template in the marketplace.',
  },
  {
    number: '02',
    title: 'Adapt with intent',
    description:
      'Remove what does not serve the client. Reshape copy, hierarchy, and flow around real goals.',
  },
  {
    number: '03',
    title: 'Ship with confidence',
    description:
      'Deliver a client-ready Framer site you can explain, defend, and sell — not a page-for-page clone.',
  },
  {
    number: '04',
    title: 'Hand off cleanly',
    description:
      'Document structure decisions, CMS setup, and delivery so clients trust what you built.',
  },
];
---

<section id="process" class="pf-section">
  <div class="pf-container">
    <SectionHead
      tag="PROCESS"
      title="Our four-step delivery framework"
      lead="Four straightforward steps that turn a template into a site you can sell, ship, and stand behind."
    />

    <div class="pf-steps">
      {steps.map((step) => (
        <article class="pf-step" data-process-card>
          <div class="pf-step-index" aria-hidden="true">
            <span>{step.number}</span>
            <span class="pf-step-dot">.</span>
          </div>
          <h3 class="pf-step-title">{step.title}</h3>
          <p class="pf-step-text">{step.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>
