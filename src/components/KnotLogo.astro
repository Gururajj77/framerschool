---
interface Props {
  size?: number;
  class?: string;
}

const { size = 24, class: className = '' } = Astro.props;
---

<img
  src="/brand/knotcms-mark.svg"
  alt=""
  width={size}
  height={size}
  aria-hidden="true"
  class:list={['pf-logo', 'pf-knot-logo', className]}
  loading="eager"
  decoding="async"
/>
