---
import '../styles/index.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'FramerSchool — Build client-ready Framer sites from templates',
  description =
    'Learn how to pick the right structure, cut what does not fit, and deliver Framer sites clients will pay for.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="color-scheme" content="dark light" />
    <title>{title}</title>
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,400;14..32,500;14..32,600;14..32,700&family=JetBrains+Mono:wght@400;500;600&family=Syne:wght@500;600;700;800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="pf-ambient" aria-hidden="true">
      <div class="pf-ambient-orb pf-ambient-orb--brand"></div>
      <div class="pf-ambient-orb pf-ambient-orb--cool"></div>
    </div>

    <div class="pf-structure-grid" data-structure-grid aria-hidden="true"></div>

    <div class="pf-cursor" data-cursor aria-hidden="true">
      <div class="pf-cursor-frame" data-cursor-frame>
        <span class="pf-cursor-line pf-cursor-line--h"></span>
        <span class="pf-cursor-line pf-cursor-line--v"></span>
        <span class="pf-cursor-corner pf-cursor-corner--tl"></span>
        <span class="pf-cursor-corner pf-cursor-corner--tr"></span>
        <span class="pf-cursor-corner pf-cursor-corner--bl"></span>
        <span class="pf-cursor-corner pf-cursor-corner--br"></span>
      </div>
      <span class="pf-cursor-dot"></span>
    </div>

    <slot />

    <script>
      import '../scripts/motion/init.ts';
    </script>
  </body>
</html>
